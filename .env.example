# === DASIR B2B PORTAL ===
DASIR_URL=https://b2b.dasirweb.fr/
DASIR_USERNAME=votre_identifiant
DASIR_PASSWORD=votre_mot_de_passe

# === ERP CONFIGURATION ===
ERP_API_URL=https://votre-erp.exemple.com/api
ERP_API_KEY=votre_cle_api
ERP_TIMEOUT_MS=5000

# === APPLICATION ===
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# === DATABASE ===
DB_PATH=./data/magasinier.db

# === CACHE ===
# Durée du cache des résultats en secondes (défaut: 5 minutes)
CACHE_TTL_SECONDS=300
